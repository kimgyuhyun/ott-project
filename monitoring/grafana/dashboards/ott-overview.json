{
  "uid": "ott-overview",
  "title": "OTT Backend Overview",
  "tags": ["ott"],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 3,
  "refresh": "10s",
  "time": { "from": "now-30m", "to": "now" },
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "인스턴스 UP (1=정상)",
      "gridPos": { "h": 4, "w": 24, "x": 0, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "ottprometheus" },
      "fieldConfig": { "defaults": { "thresholds": { "mode": "absolute", "steps": [ { "color": "red", "value": null }, { "color": "green", "value": 1 } ] } }, "overrides": [] },
      "options": { "colorMode": "background", "graphMode": "none", "textMode": "value_and_name" },
      "targets": [ { "refId": "A", "datasource": { "type": "prometheus", "uid": "ottprometheus" }, "expr": "up{job=\"ott-backend\"}", "legendFormat": "{{instance}}" } ]
    },
    {
      "id": 2,
      "type": "timeseries",
      "title": "요청 레이트 (인스턴스별, req/s)",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 4 },
      "datasource": { "type": "prometheus", "uid": "ottprometheus" },
      "fieldConfig": { "defaults": { "custom": { "drawStyle": "line", "fillOpacity": 10 }, "unit": "reqps" }, "overrides": [] },
      "targets": [ { "refId": "A", "datasource": { "type": "prometheus", "uid": "ottprometheus" }, "expr": "sum by (instance) (rate(http_server_requests_seconds_count[1m]))", "legendFormat": "{{instance}}" } ]
    },
    {
      "id": 3,
      "type": "timeseries",
      "title": "에러 레이트 (4xx / 5xx, 인스턴스별)",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 4 },
      "datasource": { "type": "prometheus", "uid": "ottprometheus" },
      "fieldConfig": { "defaults": { "custom": { "drawStyle": "line", "fillOpacity": 10 }, "unit": "reqps" }, "overrides": [] },
      "targets": [
        { "refId": "A", "datasource": { "type": "prometheus", "uid": "ottprometheus" }, "expr": "sum by (instance) (rate(http_server_requests_seconds_count{status=~\"5..\"}[1m]))", "legendFormat": "5xx {{instance}}" },
        { "refId": "B", "datasource": { "type": "prometheus", "uid": "ottprometheus" }, "expr": "sum by (instance) (rate(http_server_requests_seconds_count{status=~\"4..\"}[1m]))", "legendFormat": "4xx {{instance}}" }
      ]
    },
    {
      "id": 4,
      "type": "timeseries",
      "title": "평균 응답시간 (인스턴스별)",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 12 },
      "datasource": { "type": "prometheus", "uid": "ottprometheus" },
      "fieldConfig": { "defaults": { "custom": { "drawStyle": "line", "fillOpacity": 10 }, "unit": "s" }, "overrides": [] },
      "targets": [ { "refId": "A", "datasource": { "type": "prometheus", "uid": "ottprometheus" }, "expr": "sum by (instance) (rate(http_server_requests_seconds_sum[1m])) / sum by (instance) (rate(http_server_requests_seconds_count[1m]))", "legendFormat": "{{instance}}" } ]
    },
    {
      "id": 5,
      "type": "timeseries",
      "title": "엔드포인트별 요청 Top10 (req/s)",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 12 },
      "datasource": { "type": "prometheus", "uid": "ottprometheus" },
      "fieldConfig": { "defaults": { "custom": { "drawStyle": "line", "fillOpacity": 10 }, "unit": "reqps" }, "overrides": [] },
      "targets": [ { "refId": "A", "datasource": { "type": "prometheus", "uid": "ottprometheus" }, "expr": "topk(10, sum by (uri) (rate(http_server_requests_seconds_count[5m])))", "legendFormat": "{{uri}}" } ]
    },
    {
      "id": 6,
      "type": "timeseries",
      "title": "DB 커넥션 풀 (HikariCP, 인스턴스별)",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 20 },
      "datasource": { "type": "prometheus", "uid": "ottprometheus" },
      "fieldConfig": { "defaults": { "custom": { "drawStyle": "line", "fillOpacity": 10 }, "unit": "short" }, "overrides": [] },
      "targets": [
        { "refId": "A", "datasource": { "type": "prometheus", "uid": "ottprometheus" }, "expr": "hikaricp_connections_active", "legendFormat": "active {{instance}}" },
        { "refId": "B", "datasource": { "type": "prometheus", "uid": "ottprometheus" }, "expr": "hikaricp_connections_pending", "legendFormat": "pending {{instance}}" },
        { "refId": "C", "datasource": { "type": "prometheus", "uid": "ottprometheus" }, "expr": "hikaricp_connections_max", "legendFormat": "max {{instance}}" }
      ]
    },
    {
      "id": 7,
      "type": "timeseries",
      "title": "GC 멈춤 시간 (초/초, 인스턴스별)",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 20 },
      "datasource": { "type": "prometheus", "uid": "ottprometheus" },
      "fieldConfig": { "defaults": { "custom": { "drawStyle": "line", "fillOpacity": 10 }, "unit": "s" }, "overrides": [] },
      "targets": [ { "refId": "A", "datasource": { "type": "prometheus", "uid": "ottprometheus" }, "expr": "sum by (instance) (rate(jvm_gc_pause_seconds_sum[1m]))", "legendFormat": "{{instance}}" } ]
    },
    {
      "id": 8,
      "type": "timeseries",
      "title": "JVM 힙 메모리 (인스턴스별)",
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 28 },
      "datasource": { "type": "prometheus", "uid": "ottprometheus" },
      "fieldConfig": { "defaults": { "custom": { "drawStyle": "line", "fillOpacity": 10 }, "unit": "bytes" }, "overrides": [] },
      "targets": [ { "refId": "A", "datasource": { "type": "prometheus", "uid": "ottprometheus" }, "expr": "sum by (instance) (jvm_memory_used_bytes{area=\"heap\"})", "legendFormat": "{{instance}}" } ]
    },
    {
      "id": 9,
      "type": "timeseries",
      "title": "CPU 사용률 (프로세스, 인스턴스별)",
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 28 },
      "datasource": { "type": "prometheus", "uid": "ottprometheus" },
      "fieldConfig": { "defaults": { "custom": { "drawStyle": "line", "fillOpacity": 10 }, "unit": "percentunit", "min": 0, "max": 1 }, "overrides": [] },
      "targets": [ { "refId": "A", "datasource": { "type": "prometheus", "uid": "ottprometheus" }, "expr": "process_cpu_usage{job=\"ott-backend\"}", "legendFormat": "{{instance}}" } ]
    },
    {
      "id": 10,
      "type": "timeseries",
      "title": "활성 스레드 수 (인스턴스별)",
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 28 },
      "datasource": { "type": "prometheus", "uid": "ottprometheus" },
      "fieldConfig": { "defaults": { "custom": { "drawStyle": "line", "fillOpacity": 10 }, "unit": "short" }, "overrides": [] },
      "targets": [ { "refId": "A", "datasource": { "type": "prometheus", "uid": "ottprometheus" }, "expr": "jvm_threads_live_threads{job=\"ott-backend\"}", "legendFormat": "{{instance}}" } ]
    },
    {
      "id": 11,
      "type": "logs",
      "title": "애플리케이션 로그 (Loki)",
      "gridPos": { "h": 12, "w": 24, "x": 0, "y": 36 },
      "datasource": { "type": "loki", "uid": "ottloki" },
      "options": { "showTime": true, "wrapLogMessage": true, "enableLogDetails": true, "dedupStrategy": "none", "sortOrder": "Descending" },
      "targets": [ { "refId": "A", "datasource": { "type": "loki", "uid": "ottloki" }, "expr": "{app=\"ott-backend\"}" } ]
    }
  ]
}
