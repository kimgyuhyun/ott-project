<?xml version="1.0" encoding="UTF-8"?>
<configuration>
    <!-- Loki 푸시용 프로퍼티: compose 의 LOKI_URL/LOKI_INSTANCE 환경변수로 주입(prod), 없으면 기본값 -->
    <springProperty scope="context" name="LOKI_URL" source="loki.url" defaultValue="http://loki:3100/loki/api/v1/push"/>
    <springProperty scope="context" name="INSTANCE" source="loki.instance" defaultValue="ott-app"/>

    <!-- 콘솔 출력 설정 -->
    <!-- [%X{requestId}] [%X{clientIp}] : MdcLoggingFilter 가 심은 요청 추적 ID/클라이언트 IP -->
    <appender name="CONSOLE" class="ch.qos.logback.core.ConsoleAppender">
        <encoder>
            <pattern>%d{yyyy-MM-dd HH:mm:ss.SSS, Asia/Seoul} [%thread] [%X{requestId:-}] %-5level %logger{36} - %msg%n</pattern>
        </encoder>
    </appender>

    <!-- 파일 출력 설정 -->
    <appender name="FILE" class="ch.qos.logback.core.rolling.RollingFileAppender">
        <file>logs/ott-backend.log</file>
        <rollingPolicy class="ch.qos.logback.core.rolling.TimeBasedRollingPolicy">
            <fileNamePattern>logs/ott-backend.%d{yyyy-MM-dd}.%i.log</fileNamePattern>
            <timeBasedFileNamingAndTriggeringPolicy class="ch.qos.logback.core.rolling.SizeAndTimeBasedFNATP">
                <maxFileSize>100MB</maxFileSize>
            </timeBasedFileNamingAndTriggeringPolicy>
            <maxHistory>30</maxHistory>
        </rollingPolicy>
        <encoder>
            <pattern>%d{yyyy-MM-dd HH:mm:ss.SSS, Asia/Seoul} [%thread] [%X{requestId:-}] %-5level %logger{36} - %msg%n</pattern>
        </encoder>
    </appender>

    <!-- 인증 감사 로그 전용 파일 설정 -->
    <!-- AuthEventService 가 사용하는 "AUTH_AUDIT" 로거 전용. 로그인/로그아웃/실패 이력을 별도 파일로 분리해 추적성을 높인다. -->
    <appender name="AUTH_AUDIT" class="ch.qos.logback.core.rolling.RollingFileAppender">
        <file>logs/auth-audit.log</file>
        <rollingPolicy class="ch.qos.logback.core.rolling.TimeBasedRollingPolicy">
            <fileNamePattern>logs/auth-audit.%d{yyyy-MM-dd}.%i.log</fileNamePattern>
            <timeBasedFileNamingAndTriggeringPolicy class="ch.qos.logback.core.rolling.SizeAndTimeBasedFNATP">
                <maxFileSize>100MB</maxFileSize>
            </timeBasedFileNamingAndTriggeringPolicy>
            <!-- 보안 감사 로그는 더 오래 보관(90일) -->
            <maxHistory>90</maxHistory>
        </rollingPolicy>
        <encoder>
            <pattern>%d{yyyy-MM-dd HH:mm:ss.SSS, Asia/Seoul} [%X{requestId:-}] [%X{clientIp:-}] %-5level - %msg%n</pattern>
        </encoder>
    </appender>

    <!-- 인증 감사 전용 로거: 콘솔과 전용 파일에만 출력(루트로 전파하지 않음) -->
    <logger name="AUTH_AUDIT" level="INFO" additivity="false">
        <appender-ref ref="AUTH_AUDIT" />
        <appender-ref ref="CONSOLE" />
    </logger>

    <!-- 결제 관련 로그를 INFO 레벨로 설정 -->
    <logger name="com.ottproject.ottbackend.service.PaymentCommandService" level="INFO" additivity="false">
        <appender-ref ref="CONSOLE" />
        <appender-ref ref="FILE" />
    </logger>

    <logger name="com.ottproject.ottbackend.service.PaymentWebhookService" level="INFO" additivity="false">
        <appender-ref ref="CONSOLE" />
        <appender-ref ref="FILE" />
    </logger>

    <logger name="com.ottproject.ottbackend.service.PaymentReadService" level="INFO" additivity="false">
        <appender-ref ref="CONSOLE" />
        <appender-ref ref="FILE" />
    </logger>

    <!-- 웹훅 처리 로그를 상세하게 기록 -->
    <logger name="com.ottproject.ottbackend.controller.PaymentController" level="INFO" additivity="false">
        <appender-ref ref="CONSOLE" />
        <appender-ref ref="FILE" />
    </logger>

    <!-- 멤버십 관련 로그 -->
    <logger name="com.ottproject.ottbackend.service.MembershipSubscriptionMembershipService" level="INFO" additivity="false">
        <appender-ref ref="CONSOLE" />
        <appender-ref ref="FILE" />
    </logger>

    <!-- 플레이어 인증 관련 로그 -->
    <logger name="com.ottproject.ottbackend.service.PlaybackAuthService" level="INFO" additivity="false">
        <appender-ref ref="CONSOLE" />
        <appender-ref ref="FILE" />
    </logger>

    <!-- 스프링 프레임워크 로그 -->
    <logger name="org.springframework.security" level="INFO" />
    <logger name="org.springframework.security.oauth2" level="INFO" />
    <logger name="org.springframework.web.servlet.mvc.method.annotation.RequestMappingHandlerMapping" level="INFO" />
    <logger name="org.springframework.web.servlet.mvc.method.annotation.RequestMappingHandlerAdapter" level="INFO" />

    <!-- MyBatis 로그 -->
    <logger name="com.ottproject.ottbackend.mybatis" level="INFO" />

    <!-- Swagger 로그 -->
    <logger name="org.springdoc" level="INFO" />
    <logger name="org.springdoc.core" level="INFO" />

    <!-- Loki 푸시 appender: prod 에서만 실제 전송, 그 외 프로파일은 no-op(로컬 dev 에서 loki 없이도 안전) -->
    <springProfile name="prod">
        <appender name="LOKI" class="com.github.loki4j.logback.Loki4jAppender">
            <batchTimeoutMs>5000</batchTimeoutMs>   <!-- 기본 60초 → 5초: 로그가 거의 실시간으로 Loki 에 도착 -->
            <http><url>${LOKI_URL}</url></http>
            <format>
                <label><pattern>app=ott-backend,instance=${INSTANCE},level=%level</pattern></label>
                <message><pattern>%d{HH:mm:ss.SSS, Asia/Seoul} [%thread] [%X{requestId:-}] %-5level %logger{36} - %msg%n</pattern></message>
            </format>
        </appender>
    </springProfile>
    <springProfile name="!prod">
        <appender name="LOKI" class="ch.qos.logback.core.helpers.NOPAppender"/>
    </springProfile>

    <!-- 루트 로거 설정 -->
    <root level="INFO">
        <appender-ref ref="CONSOLE" />
        <appender-ref ref="FILE" />
        <appender-ref ref="LOKI" />
    </root>

    <!-- 에러 발생 시 스택 트레이스 전체 기록 -->
    <logger name="com.ottproject.ottbackend" level="INFO" additivity="false">
        <appender-ref ref="CONSOLE" />
        <appender-ref ref="FILE" />
        <appender-ref ref="LOKI" />
    </logger>
</configuration>
